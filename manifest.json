{
  "requiredSdkVersion": "~0.0.73",
  "name": "FullmindClassroom",
  "version": "0.0.7",
  "javascriptEntrypointUrl": "FullmindClassroom.js",
  "dataChannels": [
    {
      "name": "exit-ticket-control",
      "pushPermission": ["moderator", "presenter"],
      "replaceOrDeletePermission": ["moderator"]
    },
    {
      "name": "exit-ticket-answers",
      "pushPermission": ["all"],
      "replaceOrDeletePermission": ["moderator"]
    }
  ],
  "remoteDataSources": [
    {
      "name": "exitTicket",
      "url": "${meta_fullmindExitTicketUrl}",
      "fetchMode": "onDemand",
      "permissions": ["moderator", "viewer"]
    }
  ]
}
